# Copy this file to .env and fill in real values.

# Postgres connection string. For Vercel deploys, set this in the project's
# Environment Variables and it will be injected at build + runtime.
# Locally, use a free Neon project — https://console.neon.tech — and paste
# the pooled connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Optional: set one of these to enable real LLM generation. If both are empty
# the app uses the deterministic fallback generator and labels the UI accordingly.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
